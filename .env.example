POSTGRES_DB=opengarden
POSTGRES_USER=opengarden
POSTGRES_PASSWORD=opengarden

# ─── Database ────────────────────────────────────────────────────────────────
# Optional external Postgres URL.
# If set, scripts/up.sh will use this and skip local DB container.
# Example: DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
DATABASE_URL=

# ─── Security ─────────────────────────────────────────────────────────────────
# REQUIRED in production: replace with a long, random secret (min 32 chars).
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-long-random-string

# Session duration in minutes (default 1440 = 24 h).
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Set to "production" to enforce strict security checks at startup.
# In production mode a missing/insecure SECRET_KEY raises an error.
# ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to make CORS requests.
# Default covers local Vite dev and preview servers; override in production.
# ALLOWED_ORIGINS=https://yourdomain.com

# ─── Frontend ─────────────────────────────────────────────────────────────────
# URL the browser uses to reach the API. Override when deploying to a
# non-localhost address (e.g. on a NAS or cloud VM).
VITE_API_URL=http://localhost:8000

# URL used in email links for verification and password reset.
FRONTEND_BASE_URL=http://localhost:5173

# Email token expiry windows (minutes).
EMAIL_VERIFICATION_EXPIRE_MINUTES=60
PASSWORD_RESET_EXPIRE_MINUTES=30

# SMTP settings. Leave SMTP_HOST empty to log email links in API logs (local dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@open-garden.local
SMTP_USE_TLS=true

# ─── Abuse Controls (in-app) ────────────────────────────────────────────────
# These are per-process limits and should be paired with edge WAF/rate limits.
GLOBAL_RATE_LIMIT_PER_MINUTE=180
AUTH_LOGIN_LIMIT_PER_MINUTE=5
AUTH_REGISTER_LIMIT_PER_MINUTE=5
AUTH_VERIFY_LIMIT_PER_MINUTE=20
AUTH_RESET_LIMIT_PER_MINUTE=10
AUTH_FORGOT_LIMIT_PER_HOUR=8
AUTH_RESEND_LIMIT_PER_HOUR=12
