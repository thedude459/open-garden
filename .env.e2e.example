# Dedicated PostgreSQL database for Playwright E2E (never use production).
# Run `npm run e2e:db:ensure` to start Docker Postgres and create this database.
DATABASE_URL=postgres://garden:garden@localhost:5432/garden_e2e

# Required for NextAuth session cookies in tests.
AUTH_SECRET=local-e2e-auth-secret-min-32-chars!!

# Set automatically in CI.
# CI=true
